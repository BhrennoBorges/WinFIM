<Window x:Class="WinFIM.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinFIM.UI"
        mc:Ignorable="d"
        Title="WinFIM Guard" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#2E3440" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="WinFIM Guard" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" TextAlignment="Center"/>
                <Button Content="Dashboard" Margin="0,5" Padding="10" Command="{Binding NavigateToDashboardCommand}"/>
                <Button Content="Diretórios" Margin="0,5" Padding="10" Command="{Binding NavigateToDirectoriesCommand}"/>
                <Button Content="Baseline" Margin="0,5" Padding="10" Command="{Binding NavigateToBaselineCommand}"/>
                <Button Content="Eventos" Margin="0,5" Padding="10" Command="{Binding NavigateToEventsCommand}"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="10"/>
    </Grid>
</Window>
